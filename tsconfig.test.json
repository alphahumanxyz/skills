{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".",
    "rootDir": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "types/**/*.d.ts",
    "src/*/index.ts",
    "dev/js-harness/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".venv",
    "skills-py",
    "src/*/__tests__/**/*.ts"
  ]
}
