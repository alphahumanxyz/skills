{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "outDir": "./skills",
    "noEmit": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "types/**/*.d.ts",
    "src/*/index.ts",
  ],
  "exclude": [
    "node_modules",
    ".venv",
  ]
}
